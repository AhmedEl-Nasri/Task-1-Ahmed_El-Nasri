<?xml version="1.0"?>
<robot name="industrial_6dof_arm">

  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry><cylinder length="0.2" radius="0.1"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
  </link>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1"/>
  </joint>

  <link name="link_1">
    <visual>
      <geometry><cylinder length="0.4" radius="0.08"/></geometry>
      <material name="blue"><color rgba="0 0 0.8 1"/></material>
    </visual>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="300" lower="-3.14" upper="3.14" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <geometry><box size="0.1 0.1 0.5"/></geometry>
      <material name="red"><color rgba="0.8 0 0 1"/></material>
    </visual>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" lower="-1.57" upper="1.57" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <geometry><box size="0.1 0.1 0.4"/></geometry>
      <material name="green"><color rgba="0 0.8 0 1"/></material>
    </visual>
  </link>
  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="300" lower="-2.0" upper="2.0" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <geometry><cylinder length="0.3" radius="0.06"/></geometry>
      <material name="grey"/>
    </visual>
  </link>
  <joint name="joint_4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="1.5"/>
  </joint>

  <link name="link_5">
    <visual>
      <geometry><sphere radius="0.06"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
  </link>
  <joint name="joint_5" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-1.57" upper="1.57" velocity="1.5"/>
  </joint>

  <link name="link_6">
    <visual>
      <geometry><cylinder length="0.05" radius="0.05"/></geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="joint_6" type="revolute">
    <parent link="link_5"/>
    <child link="link_6"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-3.14" upper="3.14" velocity="2.0"/>
  </joint>

  <link name="end_effector_tip"/>
  <joint name="tool_joint" type="fixed">
    <parent link="link_6"/>
    <child link="end_effector_tip"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
  </joint>

</robot>